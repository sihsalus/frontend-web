{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.2.0"
  },
  "pages": [
    {
      "component": "referralsRoot",
      "route": "referrals"
    }
  ],
  "extensions": [
    {
      "name": "referrals-app-menu-link",
      "component": "referralsAppMenuLink",
