      "order": 15
    }
  ],
  "modals": [
    {
      "name": "referral-reasons-dialog",
      "component": "referralReasonsDialogPopup"
    }
  ],
  "workspaces": [
    {
      "name": "facility-referral-form",
      "component": "facilityReferralForm",
