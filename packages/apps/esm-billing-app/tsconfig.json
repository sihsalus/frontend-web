{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "node",
    "noEmit": true,
    "paths": {
      "mocks/*": ["./test-utils/mocks/*"],
      "tools/*": ["./tools/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "esnext"
  }
}
